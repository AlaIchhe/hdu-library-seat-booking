# HDU 图书馆座位预约系统 — 环境变量配置
# 复制此文件为 .env 并填入真实值。.env 已被 .gitignore 忽略，不会提交到仓库。

# 登录凭据（用于 SSO 密码登录，Cookie 失效时的 fallback）
HDU_USERNAME=your_student_id
HDU_PASSWORD=your_password
HDU_ORG_ID=104

# Cookie 认证（优先级高于密码登录）
# 方式 1：Cookie 字符串
# HDU_COOKIE=uid=xxx;auth=yyy

# 方式 2：Cookie JSON 文件路径（默认 tests/cookies.json）
# HDU_COOKIE_FILE=/path/to/cookies.json
